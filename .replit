modules = ["nodejs-20", "postgresql-16"]

[agent]
expertMode = true

run = "npm start"
integrations = ["javascript_database:1.0.0"]

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"
waitForPort = 5000

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "start"]

[userenv]

[userenv.production]
NODE_ENV = "production"

[userenv.shared]

[nix]
packages = ["gh", "psmisc"]
channel = "stable-25_05"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
